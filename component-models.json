      {
        "component": "multiselect",
        "name": "style",
        "label": "Style",
        "options": [
          {
            "name": "Highlight",
            "value": "highlight"
          },
          {
            "name": "Tabs",
            "value": "tabs"
          },
          {
            "name": "Divider",
            "value": "divider"
          },
          {
            "name": "Spacer Top (Small)",
            "value": "spacer-top-s"
          },
          {
            "name": "Spacer Top (Medium)",
            "value": "spacer-top-m"
          },
          {
            "name": "Spacer Top (Large)",
            "value": "spacer-top-l"
          },
          {
            "name": "Spacer Bottom (Small)",
            "value": "spacer-bottom-s"
          },
          {
            "name": "Spacer Bottom (Medium)",
            "value": "spacer-bottom-m"
          },
          {
            "name": "Spacer Bottom (Large)",
            "value": "spacer-bottom-l"
          }
