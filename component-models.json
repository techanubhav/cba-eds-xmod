      {
        "component": "text",
        "name": "tabTitle",
        "label": "Tab Title",
        "description": "Display title for the tab (defaults to Tab ID if empty)"
      },
      {
        "component": "reference",
        "name": "background",
        "label": "Background Image",
        "description": "Background image for the section (used by tabs)"
      }
