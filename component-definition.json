{
  "groups": [
    {
      "title": "Default Content",
      "id": "default",
      "components": [
        {
          "title": "Text",
          "id": "text",
          "model": "text",
          "plugins": {
            "da": {
              "name": "text",
              "type": "text"
            }
          }
        },
        {
          "title": "Image",
          "id": "image",
          "model": "image",
          "plugins": {
            "da": {
              "name": "image",
              "type": "image",
              "fields": [
                {
                  "name": "image",
                  "selector": "img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "img[alt]"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "title": "Sections",
      "id": "sections",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>"
            }
          },
          "filter": "section",
          "model": "section"
        }
      ]
    },
    {
      "title": "Blocks",
      "id": "blocks",
      "components": [
        {
          "title": "Cards",
          "id": "cards",
          "model": "cards",
          "filter": "cards",
          "plugins": {
            "da": {
              "name": "cards",
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Card Item",
          "id": "cards-item",
          "model": "cards-item",
          "plugins": {
            "da": {
              "name": "cards-item",
              "rows": 1,
              "columns": 2,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1)>picture>img[alt]"
                },
                {
                  "name": "text",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Columns",
          "id": "columns",
          "model": "columns",
          "filter": "columns",
          "plugins": {
            "da": {
              "name": "columns",
              "rows": 1,
              "columns": 2,
              "behaviour": "columns"
            }
          }
        },
        {
          "title": "Columns Row",
          "id": "columns-row",
          "model": "columns-row",
          "filter": "columns-row",
          "plugins": {
            "da": {
              "name": "columns-row",
              "behaviour": "columns-row"
            }
          }
        },
        {
          "title": "Columns Cell",
          "id": "columns-cell",
          "model": "columns-cell",
          "filter": "columns-cell",
          "plugins": {
            "da": {
              "unsafeHTML": "<div></div>",
              "behaviour": "columns-cell"
            }
          }
        },
        {
          "title": "Embed",
          "id": "embed",
          "model": "embed",
          "plugins": {
            "da": {
              "name": "embed",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "image",
                  "selector": "div>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div>div>picture>img[alt]"
                },
                {
                  "name": "embedUrl",
                  "selector": "div>div>p"
                }
              ]
            }
          }
        },
        {
          "title": "Form",
          "id": "form",
          "model": "form",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"form\"><div><div><p><a href=\"\"></a></p></div></div><div><div><p><a href=\"\"></a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div:nth-child(1)>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div:nth-child(1)>div>p>a"
                },
                {
                  "name": "actionUrl",
                  "selector": "div:nth-child(2)>div>p>a[href]"
                },
                {
                  "name": "actionUrlText",
                  "selector": "div:nth-child(2)>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Fragment",
          "id": "fragment",
          "model": "fragment",
          "plugins": {
            "da": {
              "unsafeHTML": "<div class=\"fragment\"><div><div><p><a href=\"\">Fragment URL</a></p></div></div></div>",
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Iframe",
          "id": "iframe",
          "model": "iframe",
          "plugins": {
            "da": {
              "name": "iframe",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "url",
                  "selector": "div>div>p>a[href]"
                },
                {
                  "name": "urlText",
                  "selector": "div>div>p>a"
                }
              ]
            }
          }
        },
        {
          "title": "Hero",
          "id": "hero",
          "model": "hero",
          "plugins": {
            "da": {
              "name": "hero",
              "rows": 2,
              "columns": 1,
              "fields": [
                {
                  "name": "image",
                  "selector": "div:nth-child(1)>div>picture>img[src]"
                },
                {
                  "name": "imageAlt",
                  "selector": "div:nth-child(1)>div>picture>img[alt]"
                },
                {
                  "name": "heading",
                  "selector": "div:nth-child(2)>div>h1"
                }
              ]
            }
          }
        },
        {
          "title": "Journey Map",
          "id": "journey-map",
          "model": "journey-map",
          "filter": "journey-map",
          "plugins": {
            "da": {
              "name": "journey-map",
              "rows": 1,
              "columns": 2
            }
          }
        },
        {
          "title": "Journey Map Step",
          "id": "journey-map-step",
          "model": "journey-map-step",
          "plugins": {
            "da": {
              "name": "journey-map-step",
              "rows": 2,
              "columns": 0,
              "fields": [
                {
                  "name": "title",
                  "selector": "div:nth-child(1)"
                },
                {
                  "name": "content",
                  "selector": "div:nth-child(2)"
                }
              ]
            }
          }
        },
        {
          "title": "Related Articles",
          "id": "related-articles",
          "model": "related-articles",
          "plugins": {
            "da": {
              "name": "related-articles",
              "type": "key-value-block"
            }
          }
        },
        {
          "title": "Search",
          "id": "search",
          "model": "search",
          "plugins": {
            "da": {
              "name": "search",
              "type": "key-value-block"
            }
          }
        },
        {
          "title": "Social Share",
          "id": "social-share",
          "model": "social-share",
          "plugins": {
            "da": {
              "name": "social-share",
              "rows": 0,
              "columns": 0
            }
          }
        },
        {
          "title": "Tabs",
          "id": "tabs",
          "model": "tabs",
          "plugins": {
            "da": {
              "name": "tabs",
              "rows": 1,
              "columns": 1
            }
          }
        },
        {
          "title": "Teaser",
          "id": "teaser",
          "model": "teaser",
          "plugins": {
            "da": {
              "name": "teaser",
              "rows": 1,
              "columns": 1,
              "fields": [
                {
                  "name": "text",
                  "selector": "div>div>p"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}