{
  "definitions": [
    {
      "title": "Embed",
      "id": "embed",
      "model": "embed",
      "plugins": {
        "da": {
          "name": "embed",
          "rows": 1,
          "columns": 1,
          "fields": [
            { "name": "image", "selector": "div>div>picture>img[src]" },
            { "name": "imageAlt", "selector": "div>div>picture>img[alt]" },
            { "name": "embedUrl", "selector": "div>div>p" }
          ]
        }
      }
    }
  ],
  "models": [
    {
      "id": "embed",
      "fields": [
        {
          "component": "select",
          "name": "classes",
          "label": "Variation",
          "options": [
            { "name": "With placeholder", "value": "" },
            { "name": "No placeholder", "value": "no-placeholder" }
          ]
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Placeholder Image",
          "multi": false,
          "description": "Optional thumbnail shown before the video plays. Leave empty when using 'No placeholder' variation."
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "imageAlt",
          "label": "Alt Text",
          "value": ""
        },
        {
          "component": "richtext",
          "name": "embedUrl",
          "label": "Embed URL",
          "valueType": "string",
          "required": true,
          "description": "URL to embed (YouTube, Vimeo, Twitter, or any embed URL)"
        }
      ]
    }
  ],
  "filters": []
}
